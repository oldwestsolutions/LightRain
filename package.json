{
  "name": "lightrain-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @lightrain/web",
    "dev:wallet": "npm run dev -w @lightrain/wallet",
    "dev:admin": "npm run dev -w @lightrain/admin",
    "build": "node scripts/lightrain-build.mjs",
    "build:web": "npm run build -w @lightrain/web",
    "build:wallet": "npm run build -w @lightrain/wallet",
    "build:admin": "npm run build -w @lightrain/admin",
    "lint": "npm run lint -w @lightrain/web"
  },
  "engines": {
    "node": ">=18"
  }
}
